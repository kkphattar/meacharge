# Copy this file to .env and fill in the values
# cp .env.example .env

# SendGrid SMTP — mail_username ต้องเป็น "apikey" เสมอ
mail_server=smtp.sendgrid.net
mail_username=apikey
mail_password=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
mail_sender=your_verified_sender@example.com
secret_key=your_random_secret_key
database_url=sqlite:///db.sqlite3
mail_server=smtp.gmail.com
mail_admin=admin@example.com
mail_admin_employee=admin@example.com
mail_admin_white=admin@example.com
mail_admin_orange=admin@example.com
mail_admin_white_temp=admin@example.com
mail_admin_orange_temp=admin@example.com
web_url=https://your-ngrok-or-domain.app
channel_id=your_line_channel_id
channel_secret=your_line_channel_secret
ocppserver=https://your-ocpp-server
ocpphost=your-ocpp-host
username=your_api_username
pwd=your_api_password
DEV_LOG_KEY=change-this-to-a-random-string
